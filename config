# ==============================================
# Ghostty Config
# ==============================================

# Font Configuration
font-family = "JetBrains Mono NL"
font-family-bold = "JetBrains Mono NL Bold"
font-family-italic = "JetBrains Mono NL Italic"
font-family-bold-italic = "JetBrains Mono NL Bold Italic"
font-size = 13.5
font-thicken = true
font-thicken-strength = 180

# Extra vertical and horizontal spacing
adjust-cell-height = 20%
adjust-cell-width = 2%

# Cursor
cursor-style = bar
cursor-style-blink = false

# Window Padding & Decoration
window-padding-balance = true
window-decoration = auto
window-theme = ghostty
background-opacity = 0.98
background-blur-radius = 20

# Theme
theme = "Catppuccin Mocha"

# Mouse Behaviour
mouse-hide-while-typing = true

# Links
link-url = true

# Scrollback
scrollback-limit = 100000

# Cmd+a sends Ctrl-B (\x02), which tmux treats as the prefix.
# (Cmd is a terminal-app modifier and never reaches tmux directly,
#  so we emit the prefix byte here instead.)
keybind = cmd+a=text:\x02

# macOS Specifics
macos-option-as-alt = true

# General Application Behavior
quit-after-last-window-closed = true
resize-overlay = never

# Clipboard
clipboard-paste-protection = true
copy-on-select = true

# Update
auto-update = off

